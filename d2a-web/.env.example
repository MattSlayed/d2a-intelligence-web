# ── D2A Intelligence Web — environment ───────────────────────────────
# Copy to .env.local for local dev, and set the same in Vercel project settings.

# REQUIRED — your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Model id. Default keeps cost low for an open-link demo.
# Use claude-opus-4-8 for deeper reasoning (higher cost).
MODEL=claude-sonnet-4-6

# Live web grounding via the research agent. OFF by default for reliability:
# heavy web search needs a higher Anthropic usage tier — Tier 1's 30,000
# input-tokens/min rate-limits deep sweeps (the run falls back to search-free).
# Set true once you're on Tier 2+.
ENABLE_WEB_SEARCH=false
WEB_SEARCH_TOOL=web_search_20260209
